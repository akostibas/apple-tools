#compdef apple-tools
#
# Zsh completion for apple-tools.
#
# This is a thin adapter: all the logic lives in the binary's hidden
# `apple-tools __complete <words...>` subcommand, which introspects the tool
# registry at runtime and prints the candidates for the token under the cursor.
# Because everything derives from the live ToolDefinition metadata, completion
# can never drift from the actual CLI.
#
# Install: put this file on your $fpath (its directory must be added *before*
# `compinit` runs), or source it directly from ~/.zshrc — see the README.

_apple-tools() {
  local -a words_to_complete
  # $words holds the full command line; $CURRENT is the 1-based index of the
  # word under the cursor. Forward everything after the command name (index 1)
  # up to and including the current word — the last element is the partial
  # token being completed (empty when the cursor is on a fresh word).
  words_to_complete=("${words[@]:1:$((CURRENT - 1))}")

  local -a candidates
  local line value desc
  # Each line from __complete is `value` or `value<TAB>description`.
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    value="${line%%$'\t'*}"
    if [[ "$line" == *$'\t'* ]]; then
      desc="${line#*$'\t'}"
      candidates+=("${value}:${desc}")
    else
      candidates+=("$value")
    fi
  done < <(apple-tools __complete "${words_to_complete[@]}" 2>/dev/null)

  # _describe renders the value:description pairs with aligned help text.
  _describe -t apple-tools 'apple-tools' candidates
}

_apple-tools "$@"
