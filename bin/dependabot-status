#!/usr/bin/env bash
#
# dependabot-status — surface open Dependabot PRs for a repo.
#
# Prints a short summary of open Dependabot PRs, or nothing at all when there
# are none. Wired into the Claude Code SessionStart hook (.claude/settings.json)
# so open dependency PRs are visible the moment a session starts in this repo.
#
# Usage:
#   dependabot-status              # query the current directory's repo (default)
#   dependabot-status owner/repo   # query a specific repo (used for testing)
#
# Deliberately fail-quiet: any missing tool, auth problem, or network error
# results in NO output and a clean exit, so it can never disrupt session start.

command -v gh >/dev/null 2>&1 || exit 0
command -v jq >/dev/null 2>&1 || exit 0

repo_args=()
[ "$#" -gt 0 ] && repo_args=(--repo "$1")

gh pr list "${repo_args[@]}" --author 'app/dependabot' --state open \
  --json number,title,url 2>/dev/null \
| jq -r 'if length > 0
    then "⚠️  \(length) open Dependabot PR(s) — consider reviewing:\n"
         + (map("  #\(.number)  \(.title)\n     \(.url)") | join("\n"))
    else empty end' 2>/dev/null

exit 0
